# ──────────────────────────────────────────────────────────────────────────
# HEOR Provenance Agent — environment template
# Copy to .env and fill in. NEVER commit .env (the repo is PUBLIC).
# ──────────────────────────────────────────────────────────────────────────

# ── LLM (provider-agnostic, OpenAI-compatible API) ──────────────────────────
# The code never hardcodes a provider. Point these at any free,
# OpenAI-compatible endpoint. Two known-good options:
#
#   Groq:    LLM_BASE_URL=https://api.groq.com/openai/v1
#            LLM_MODEL=llama-3.3-70b-versatile
#
#   Gemini:  LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#            LLM_MODEL=gemini-2.0-flash
#
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=llama-3.3-70b-versatile

# ── Chainlink Confidential AI Attester (optional provenance anchor) ─────────
# Runs an LLM over a document inside an AWS Nitro enclave and returns signed
# content/request/response digests (npm run confidential). Bearer key:
CHAINLINK_CONF_AI_KEY=
# Optional base URL override. Defaults to the dev preview.
# CHAINLINK_CONF_AI_URL=https://confidential-ai-dev-preview.cldev.cloud
# ⚠ The dev preview MAY LOG INPUTS — send only SYNTHETIC data, never real PHI/PII.
# Fast path for live Generate: set to ONE model id (e.g. gemma4) to call only
# that enclave model instead of racing gemma4 + qwen3.6 — cuts load/timeout risk
# when the dev preview is contended. Unset = dual-model race.
# ENCLAVE_SINGLE_MODEL=gemma4

# ── PubMed E-utilities ──────────────────────────────────────────────────────
# Optional. Without a key NCBI allows ~3 requests/sec; with one, ~10/sec.
# Get one free at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# E-utilities asks tools to identify themselves (helps with rate-limit grace).
# These are not secrets.
NCBI_TOOL=heor-provenance
NCBI_EMAIL=you@example.com

# ── Walrus (testnet blob storage) ───────────────────────────────────────────
# Public testnet publisher/aggregator. The code falls back to these exact
# defaults if unset, so they're optional — override only to use your own.
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# ── ENS (identity / provenance pin, Sepolia testnet) ────────────────────────
# The name registered via the ENS v2 preview (sepolia.app.ens.domains).
ENS_NAME=

# Sepolia JSON-RPC endpoint (e.g. Alchemy/Infura/public). Required for both
# reads and writes.
SEPOLIA_RPC_URL=

# THROWAWAY testnet key that owns/manages ENS_NAME and holds only Sepolia test
# ETH. NEVER commit this. With or without the 0x prefix.
ENS_PRIVATE_KEY=

# ── Direct .eth registration (npm run ens-register) ─────────────────────────
# Registers a fresh name on-chain via the ENS v2 TestnetV1PremigrationRegistrar
# (single tx, no commit), bypassing the web app. The classic ETHRegistrarController
# (0xfb3cE5D0…F1f968) was de-authorized on Sepolia by the v2 migration — see the
# header comment in scripts/ens-register.ts. The label to register, WITHOUT the
# .eth suffix (e.g. my-agent-demo).
ENS_REGISTER_LABEL=

# Optional: registration length in years (default 1).
# ENS_REGISTER_DURATION_YEARS=1

# Optional: override the registrar. Defaults to the active Sepolia ENS v2 registrar
# 0xdf60C561Ca35AD3C89D24BbA854654b1c3477078. If a future redeploy moves it, find
# the new authorized registrar with: npx tsx scripts/ens-find-controller.ts
# ENS_CONTROLLER_ADDRESS=

# Optional: wei to send with register(). The v2 registrar currently charges no
# fee (default 0); set only if a redeploy reintroduces a price.
# ENS_REGISTER_VALUE_WEI=

# Optional: override the ENS registry address. Defaults to the canonical
# 0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e used by mainnet + the Sepolia v2
# preview. Set only if the preview ever moves the registry.
# ENS_REGISTRY_ADDRESS=

# Optional: override the Sepolia PublicResolver used by `npm run ens-set-resolver`.
# Defaults to 0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5 (ens-contracts Sepolia).
# ENS_PUBLIC_RESOLVER_ADDRESS=

# Optional: override the Sepolia NameWrapper used for wrapped-name resolver sets.
# Defaults to 0x0635513f179D50A207757E05759CbD106d7dFcE8 (ens-contracts Sepolia).
# ENS_NAMEWRAPPER_ADDRESS=
# ──────────────────────────────────────────────────────────────────────────
